OPENAI_API_KEY=your-openai-api-key-here

# LinkedIn API (RapidAPI wrapper)
RAPIDAPI_KEY=your-rapidapi-key-here

# GitHub (optional — public API works without token, but rate-limited)
GITHUB_TOKEN=your-github-token-here

# Target job locations (comma-separated)
TARGET_LOCATIONS=Boston,Raleigh,Remote

# Graduation date window (YYYY-MM format)
GRADUATION_EARLIEST=2025-12
GRADUATION_LATEST=2026-08

# Pipeline settings
TOP_K_CANDIDATES=100

# MLflow
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=recruitment-filtration-agent
