# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# GitHub (optional — public API works without token, but rate-limited)
GITHUB_TOKEN=your-github-token-here

# Target job locations (comma-separated)
TARGET_LOCATIONS=Boston,Raleigh,Remote

# Graduation date window (YYYY-MM format)
GRADUATION_EARLIEST=2025-12
GRADUATION_LATEST=2027-06

# Pipeline settings
TOP_K_CANDIDATES=100

# Google Drive — service account JSON key and folder IDs
# See README for setup instructions
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json
GDRIVE_RESUME_FOLDER_ID=
GDRIVE_ACCEPTED_FOLDER_ID=
GDRIVE_REJECTED_FOLDER_ID=
